{
	"nodes":[
		{"id":"legend","type":"text","text":"# 🗺️ Event Storming — Enforce\n\nUse cases **C1 (Restrict Recording)** and **C2 (Stop Recording)**, plus the **compliance gate** in Call Scheduling that blocks non-compliant calls at scheduling time. Two enforcement seams: pre-call (URL check at schedule time) and in-call (consent decision at join time).\n\n**Colour key** — 🟧 Event · 🟦 Command · 🟩 Actor · 🟥 Policy · 🟪 Service · ⬛ Read model","x":-800,"y":-960,"width":1600,"height":180,"color":"6"},

		{"id":"g_precall","type":"group","x":-2200,"y":-680,"width":1400,"height":480,"color":"3","label":"Pre-call enforcement — scheduling time (gong-call-schedulers)"},
		{"id":"g_incall","type":"group","x":-2200,"y":-100,"width":1400,"height":400,"color":"1","label":"In-call enforcement — consent decision time (gong-data-capture)"},
		{"id":"g_postcall","type":"group","x":-600,"y":-100,"width":1000,"height":400,"color":"2","label":"Post-decision — recording boundary"},

		{"id":"act_sched_sys","type":"text","text":"📅 Calendar sync\n/ scheduling pipeline","x":-2180,"y":-620,"width":240,"height":70,"color":"5"},
		{"id":"cmd_schedule","type":"text","text":"**Schedule a call**\nCallScheduler validation chain fires\n(CheckCompliance is one validator)","x":-1880,"y":-620,"width":380,"height":70,"color":"3"},
