		{"id":"evt_warn_email","type":"text","text":"📨 Non-compliant URL warning email\n→ enqueued to rep\n(isEnforced=false path only)","x":-1000,"y":-540,"width":380,"height":80,"color":"2"},
		{"id":"ds_dcp","type":"text","text":"🗄️ DcpJumpPageSettings\n(isEnabled, isEnforced)\nread by CheckCompliance","x":-1440,"y":-480,"width":380,"height":80,"color":"6"},

