		{"id":"ds_sync","type":"text","text":"Updates provider tokens / user mappings\n(WebEx: refreshes OAuth tokens\nZoom: syncs user list + credentials)\nNo outbound scheduling event","x":-400,"y":-317,"width":400,"height":115,"color":"6"},
