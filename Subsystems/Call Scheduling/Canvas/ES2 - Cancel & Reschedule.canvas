		{"id":"act_gdpr","type":"text","text":"🔒 GDPR / offboard\npurge-company event","x":-3180,"y":840,"width":320,"height":60,"color":"5"},
		{"id":"cmd_cancel_internal","type":"text","text":"**Cancel internal meetings**\nResolution = INTERNAL_MEETING_RECORDING_DISABLED\n(UC-C5)","x":-2700,"y":840,"width":480,"height":115,"color":"4"},
		{"id":"cmd_compliance","type":"text","text":"**Resolution change: COMPLIANCE_ENFORCING**\nCheckCompliance detects non-Gong URL + isEnforced\nSchedulingCallService#cancelExistingCallDueToResolutionChange\n(UC-C3) → [[Subsystems/Call Scheduling/Compliance URL Enforcement]]","x":-2700,"y":283,"width":480,"height":175,"color":"4"},
		{"id":"cmd_cancel_email","type":"text","text":"**Cancel by compliance email**\ncallSchedulerClient.cancelScheduledCallByConsentEmail\nSkipCode = CANCEL_BY_COMPLIANCE_EMAIL\n(UC-C2)","x":-2700,"y":526,"width":480,"height":115,"color":"4"},
		{"id":"act_email_c","type":"text","text":"📧 Consent email\n(participant denies)","x":-3180,"y":554,"width":320,"height":60,"color":"5"},
