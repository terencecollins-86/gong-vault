	"nodes":[
		{"id":"g_recurring","type":"group","x":-3000,"y":40,"width":3460,"height":780,"color":"2","label":"E — Recurring series (UC-E1 + UC-E2)"},
		{"id":"g_restore","type":"group","x":-3000,"y":-780,"width":3320,"height":540,"color":"3","label":"D — Restore (UC-D1)"},
		{"id":"legend","type":"text","text":"# 🗺️ Event Storming — Restore & Recurring (D + E)\n\nUse cases **D1 (Restore)** and **E1–E2 (Recurring)**. Restore is the inverse of UC-C1 — the owner reactivates a cancelled call. Recurring is driven by a background scheduled task (~2h), not event-by-event — it walks the series forward and schedules each occurrence within the lookahead window.\n\n**Colour key** — 🟧 Event · 🟦 Command · 🟩 Actor · 🟥 Policy · 🟪 Service · ⬛ Data store","x":-2980,"y":-1200,"width":1600,"height":200,"color":"6"},
		{"id":"act_rep_d","type":"file","file":"Subsystems/Call Scheduling/Canvas/Actors/RepUser.md","x":-2960,"y":-620,"width":320,"height":60,"color":"5"},
		{"id":"cmd_restore","type":"text","text":"**Restore cancelled call by owner**\nPOST /scheduled-calls/restore-by-owner\nRestoreCancelledCallService#restoreCancelledCallByOwner\n(UC-D1)","x":-2480,"y":-640,"width":520,"height":145,"color":"3"},
		{"id":"svc_rest_d","type":"file","file":"Subsystems/Call Scheduling/Canvas/Web - REST/ScheduledCallsActionsController.md","x":-1840,"y":-590,"width":460,"height":60,"color":"3"},
