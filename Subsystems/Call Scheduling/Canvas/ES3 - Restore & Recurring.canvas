		{"id":"crud_restore","type":"text","text":"CRUD = **UPDATE**\nResolution = RESTORED_BY_OWNER\nSkipCode cleared\npublic.call restored to SCHEDULED","x":-110,"y":-705,"width":380,"height":115,"color":"2"},
		{"id":"ds_call_d","type":"text","text":"🗄️ operational.public.call\nRestored to SCHEDULED\nor cancelled per occurrence","x":-730,"y":-365,"width":380,"height":85,"color":"6"},
		{"id":"note_restore","type":"text","text":"⚠️ Restore only available to owner (`cancel-by-owner` path). Calls cancelled by compliance / system cannot be self-restored — those require ops intervention via troubleshooter.","x":-170,"y":-467,"width":380,"height":145,"color":"4"},
